<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Floatingclouds" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/app_primary</item>
        <item name="colorPrimaryDark">@color/app_primary</item>
        <item name="colorAccent">@color/app_primary</item>
        <item name="colorControlNormal">@color/app_outline</item>
        <item name="colorError">@color/app_error</item>
        <item name="android:colorBackground">@color/app_surface</item>
        <item name="android:textColorPrimary">@color/app_on_surface</item>
        <item name="android:textColorSecondary">@color/app_on_surface_variant</item>
        <item name="android:statusBarColor">@color/app_surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/app_surface</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.AppCompat.Dialog.Alert</item>
        <item name="buttonStyle">@style/Widget.Floatingclouds.Button</item>
    </style>

    <style name="Theme.Floatingclouds.Transparent" parent="Theme.Floatingclouds">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="windowActionBar">@null</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Translucent</item>
    </style>

    <style name="Widget.Floatingclouds.Button" parent="Widget.AppCompat.Button.Colored">
        <item name="backgroundTint">@color/app_primary</item>
        <item name="android:textColor">@color/app_on_primary</item>
    </style>
</resources>
